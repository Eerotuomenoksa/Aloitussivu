rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email in [
          'eero.tuomenoksa@gmail.com',
          'seniorsurf.suomi@gmail.com'
        ];
    }

    function isValidReport() {
      return request.resource.data.keys().hasOnly([
          'id',
          'type',
          'name',
          'url',
          'category',
          'source',
          'createdAt',
          'note',
          'status',
          'updatedAt'
        ])
        && request.resource.data.id is string
        && request.resource.data.type in ['new', 'broken', 'wrong']
        && request.resource.data.name is string
        && request.resource.data.url is string
        && request.resource.data.source is string
        && request.resource.data.createdAt is string
        && request.resource.data.note is string
        && request.resource.data.status == 'pending'
        && request.resource.data.url.size() <= 500
        && request.resource.data.name.size() <= 160
        && request.resource.data.note.size() <= 1000;
    }

    function onlyTogglesVisibility() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'active',
        'updatedAt'
      ])
      && request.resource.data.active is bool
      && request.resource.data.updatedAt is string;
    }

    function onlyReviewsLinkReport() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'status',
        'reviewedAt',
        'reviewedBy',
        'updatedAt',
        'approvedLinkId',
        'reviewReason'
      ])
      && request.resource.data.status in ['approved', 'rejected']
      && request.resource.data.reviewedAt is string
      && request.resource.data.reviewedBy is string
      && request.resource.data.updatedAt is string;
    }

    match /linkReports/{reportId} {
      allow create: if isValidReport();
      allow read, delete: if isAdmin();
      allow update: if isAdmin() || (request.auth != null && onlyReviewsLinkReport());
    }

    match /approvedLinks/{linkId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /blockedLinks/{linkId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /scamAlerts/{alertId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (request.auth != null && onlyTogglesVisibility());
    }

    match /ncscScrapeLog/{logId} {
      allow read: if true;
      allow write: if false;
    }

    match /adminStats/{statId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
