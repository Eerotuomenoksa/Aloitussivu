rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && (
          request.auth.uid in [
            'hZU1Fhi7EncUZm7UDzKMDaHFzaV2'
          ]
          || (
            request.auth.token.email_verified == true
            && request.auth.token.email in [
              'eero.tuomenoksa@gmail.com',
              'seniorsurf.suomi@gmail.com'
            ]
          )
        );
    }

    function isValidReport(reportId) {
      return request.resource.data.keys().hasOnly([
          'id',
          'type',
          'name',
          'url',
          'category',
          'source',
          'createdAt',
          'note',
          'status',
          'updatedAt'
        ])
        && request.resource.data.id == reportId
        && request.resource.data.id is string
        && request.resource.data.type in ['new', 'broken', 'wrong']
        && request.resource.data.name is string
        && request.resource.data.url is string
        && request.resource.data.source is string
        && request.resource.data.createdAt is string
        && request.resource.data.note is string
        && request.resource.data.status == 'pending'
        && request.resource.data.url.matches('https://.+')
        && request.resource.data.url.size() <= 500
        && request.resource.data.name.size() <= 160
        && request.resource.data.note.size() <= 1000;
    }

    function isValidFeedbackCreate(feedbackId) {
      return request.resource.data.keys().hasOnly([
          'id',
          'type',
          'title',
          'description',
          'page',
          'status',
          'publicNote',
          'createdAt',
          'updatedAt',
          'client',
          'hasScreenshot'
        ])
        && request.resource.data.id == feedbackId
        && request.resource.data.id is string
        && request.resource.data.type in ['bug', 'content', 'link', 'accessibility', 'idea', 'other']
        && request.resource.data.title is string
        && request.resource.data.description is string
        && request.resource.data.page is string
        && request.resource.data.status == 'new'
        && request.resource.data.publicNote == ''
        && request.resource.data.createdAt is string
        && request.resource.data.updatedAt is string
        && request.resource.data.title.size() >= 3
        && request.resource.data.title.size() <= 140
        && request.resource.data.description.size() >= 5
        && request.resource.data.description.size() <= 1600
        && request.resource.data.page.size() <= 120
        && (!('hasScreenshot' in request.resource.data) || request.resource.data.hasScreenshot is bool)
        && (!('client' in request.resource.data)
          || (
            request.resource.data.client is map
            && request.resource.data.client.keys().hasOnly([
              'browserName',
              'browserVersion',
              'osName',
              'deviceType',
              'userAgent',
              'platform',
              'language',
              'viewport',
              'screen',
              'timezone',
              'touch'
            ])
            && request.resource.data.client.browserName is string
            && request.resource.data.client.browserName.size() <= 80
            && (!('browserVersion' in request.resource.data.client) || (request.resource.data.client.browserVersion is string && request.resource.data.client.browserVersion.size() <= 80))
            && request.resource.data.client.osName is string
            && request.resource.data.client.osName.size() <= 80
            && request.resource.data.client.deviceType in ['desktop', 'tablet', 'mobile', 'unknown']
            && request.resource.data.client.userAgent is string
            && request.resource.data.client.userAgent.size() <= 500
            && request.resource.data.client.platform is string
            && request.resource.data.client.platform.size() <= 120
            && request.resource.data.client.language is string
            && request.resource.data.client.language.size() <= 40
            && request.resource.data.client.viewport is string
            && request.resource.data.client.viewport.size() <= 40
            && request.resource.data.client.screen is string
            && request.resource.data.client.screen.size() <= 40
            && request.resource.data.client.timezone is string
            && request.resource.data.client.timezone.size() <= 80
            && request.resource.data.client.touch is bool
          ));
    }

    function isValidFeedbackAttachmentCreate(feedbackId) {
      return request.resource.data.keys().hasOnly([
          'id',
          'feedbackId',
          'screenshot',
          'createdAt'
        ])
        && request.resource.data.id == feedbackId
        && request.resource.data.feedbackId == feedbackId
        && request.resource.data.createdAt is string
        && request.resource.data.screenshot is map
        && request.resource.data.screenshot.keys().hasOnly(['name', 'type', 'size', 'dataUrl'])
        && request.resource.data.screenshot.name is string
        && request.resource.data.screenshot.name.size() <= 180
        && request.resource.data.screenshot.type in ['image/png', 'image/jpeg', 'image/webp', 'image/gif']
        && request.resource.data.screenshot.size is int
        && request.resource.data.screenshot.size > 0
        && request.resource.data.screenshot.size <= 460800
        && request.resource.data.screenshot.dataUrl is string
        && request.resource.data.screenshot.dataUrl.size() <= 700000
        && request.resource.data.screenshot.dataUrl.matches('data:image/(png|jpeg|webp|gif);base64,.+');
    }

    function isValidTestFeedbackResponseCreate(responseId) {
      return request.resource.data.keys().hasOnly([
          'id',
          'formVersion',
          'createdAt',
          'deviceTypes',
          'useMode',
          'webExperience',
          'purposeClear',
          'firstImpression',
          'pageFeelings',
          'foundServices',
          'searchedFor',
          'missingService',
          'categoryClarity',
          'unclearCategory',
          'municipalityCorrect',
          'localServicesUseful',
          'missingLocalLink',
          'localNewsUseful',
          'featureRatings',
          'missingFeature',
          'textSize',
          'contrastClarity',
          'mobileEase',
          'difficultPart',
          'tourViewed',
          'tourHelpful',
          'tourFeedback',
          'usefulnessRating',
          'easeRating',
          'recommend',
          'mostImportantFix',
          'bestThing'
        ])
        && request.resource.data.keys().hasAll([
          'id',
          'formVersion',
          'createdAt',
          'deviceTypes',
          'useMode',
          'webExperience',
          'purposeClear',
          'firstImpression',
          'pageFeelings',
          'foundServices',
          'searchedFor',
          'missingService',
          'categoryClarity',
          'unclearCategory',
          'municipalityCorrect',
          'localServicesUseful',
          'missingLocalLink',
          'localNewsUseful',
          'featureRatings',
          'missingFeature',
          'textSize',
          'contrastClarity',
          'mobileEase',
          'difficultPart',
          'tourViewed',
          'tourHelpful',
          'tourFeedback',
          'usefulnessRating',
          'easeRating',
          'recommend',
          'mostImportantFix',
          'bestThing'
        ])
        && request.resource.data.id == responseId
        && request.resource.data.id is string
        && request.resource.data.formVersion == '2026-06'
        && request.resource.data.createdAt is string
        && request.resource.data.deviceTypes is list
        && request.resource.data.deviceTypes.size() >= 1
        && request.resource.data.deviceTypes.size() <= 3
        && request.resource.data.deviceTypes.hasOnly(['phone', 'tablet', 'computer'])
        && request.resource.data.useMode in ['', 'self', 'withSomeone', 'guidance']
        && request.resource.data.webExperience in ['', 'often', 'sometimes', 'needsHelp', 'observer']
        && request.resource.data.purposeClear in ['', 'yes', 'partly', 'no']
        && request.resource.data.firstImpression is string
        && request.resource.data.firstImpression.size() <= 1200
        && request.resource.data.pageFeelings is list
        && request.resource.data.pageFeelings.size() <= 8
        && request.resource.data.pageFeelings.hasOnly(['clear', 'calm', 'useful', 'tooFull', 'confusing', 'pleasant'])
        && request.resource.data.foundServices in ['yes', 'partly', 'no']
        && request.resource.data.searchedFor is string
        && request.resource.data.searchedFor.size() <= 900
        && request.resource.data.missingService is string
        && request.resource.data.missingService.size() <= 900
        && request.resource.data.categoryClarity in ['', 'yes', 'partly', 'no']
        && request.resource.data.unclearCategory is string
        && request.resource.data.unclearCategory.size() <= 900
        && request.resource.data.municipalityCorrect in ['', 'yes', 'no', 'notSeen']
        && request.resource.data.localServicesUseful in ['', 'yes', 'partly', 'no', 'notUsed']
        && request.resource.data.missingLocalLink is string
        && request.resource.data.missingLocalLink.size() <= 900
        && request.resource.data.localNewsUseful in ['', 'yes', 'partly', 'no', 'notSeen']
        && request.resource.data.featureRatings is map
        && request.resource.data.featureRatings.keys().hasOnly([
          'weather',
          'assistant',
          'internetSearch',
          'scamAlerts',
          'nearby',
          'favorites',
          'categorySearch',
          'namedays',
          'localNews'
        ])
        && (!('weather' in request.resource.data.featureRatings) || request.resource.data.featureRatings.weather in [1, 2, 3, 4, 5])
        && (!('assistant' in request.resource.data.featureRatings) || request.resource.data.featureRatings.assistant in [1, 2, 3, 4, 5])
        && (!('internetSearch' in request.resource.data.featureRatings) || request.resource.data.featureRatings.internetSearch in [1, 2, 3, 4, 5])
        && (!('scamAlerts' in request.resource.data.featureRatings) || request.resource.data.featureRatings.scamAlerts in [1, 2, 3, 4, 5])
        && (!('nearby' in request.resource.data.featureRatings) || request.resource.data.featureRatings.nearby in [1, 2, 3, 4, 5])
        && (!('favorites' in request.resource.data.featureRatings) || request.resource.data.featureRatings.favorites in [1, 2, 3, 4, 5])
        && (!('categorySearch' in request.resource.data.featureRatings) || request.resource.data.featureRatings.categorySearch in [1, 2, 3, 4, 5])
        && (!('namedays' in request.resource.data.featureRatings) || request.resource.data.featureRatings.namedays in [1, 2, 3, 4, 5])
        && (!('localNews' in request.resource.data.featureRatings) || request.resource.data.featureRatings.localNews in [1, 2, 3, 4, 5])
        && request.resource.data.missingFeature is string
        && request.resource.data.missingFeature.size() <= 900
        && request.resource.data.textSize in ['', 'good', 'tooSmall', 'tooLarge', 'changed']
        && request.resource.data.contrastClarity in ['', 'yes', 'partly', 'no']
        && request.resource.data.mobileEase in ['', 'yes', 'partly', 'no', 'notTested']
        && request.resource.data.difficultPart is string
        && request.resource.data.difficultPart.size() <= 1200
        && request.resource.data.tourViewed in ['', 'yes', 'partly', 'no']
        && request.resource.data.tourHelpful in ['', 'yes', 'partly', 'no', 'notViewed']
        && request.resource.data.tourFeedback is string
        && request.resource.data.tourFeedback.size() <= 900
        && request.resource.data.usefulnessRating in [1, 2, 3, 4, 5]
        && request.resource.data.easeRating in [0, 1, 2, 3, 4, 5]
        && request.resource.data.recommend in ['', 'yes', 'maybe', 'no']
        && request.resource.data.mostImportantFix is string
        && request.resource.data.mostImportantFix.size() >= 3
        && request.resource.data.mostImportantFix.size() <= 1200
        && request.resource.data.bestThing is string
        && request.resource.data.bestThing.size() <= 900;
    }

    match /linkReports/{reportId} {
      allow create: if isValidReport(reportId);
      allow read, delete: if isAdmin();
      allow update: if isAdmin();
    }

    match /feedbackItems/{feedbackId} {
      allow read: if true;
      allow create: if isValidFeedbackCreate(feedbackId);
      allow update, delete: if isAdmin();
    }

    match /feedbackAttachments/{feedbackId} {
      allow read, update, delete: if isAdmin();
      allow create: if isValidFeedbackAttachmentCreate(feedbackId);
    }

    match /testFeedbackResponses/{responseId} {
      allow create: if isValidTestFeedbackResponseCreate(responseId);
      allow read, delete: if isAdmin();
      allow update: if false;
    }

    match /approvedLinks/{linkId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /blockedLinks/{linkId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /scamAlerts/{alertId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /ncscScrapeLog/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /adminStats/{statId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /usageStats/{dateId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
