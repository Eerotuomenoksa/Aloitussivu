      },
      {
        "name": "linkReports",
        "public_read": false,
        "public_create": true,
        "admin_read": true,
        "admin_update": true,
        "admin_delete": true,
        "validation_summary": "strict allowed keys; type enum; status must be pending on create; url must match https://.+; bounded field lengths"
      },
      {
        "name": "approvedLinks",
        "public_read": true,
        "public_create": false,
        "admin_create": true,
