  "known_architecture_risks": [
    {
      "id": "multi_page_rewrite",
      "severity": "medium",
      "description": "Vite builds multiple HTML entrypoints but Firebase Hosting rewrites all paths to /index.html.",
      "recommendation": "Verify intended production routing and adjust rewrites if direct subpage URLs must serve their own HTML files."
    },
    {
      "id": "typescript_data_volume",
      "severity": "medium",
      "description": "Large static datasets are stored directly in TypeScript modules.",
      "recommendation": "Move source data to JSON or CSV and generate typed modules during build."
    },
    {
      "id": "link_truth_source",
      "severity": "medium",
      "description": "Link state exists in static modules, generated files, Firestore and localStorage.",
      "recommendation": "Define one canonical link registry and explicit publication workflow."
    },
    {
      "id": "firestore_screenshot_storage",
      "severity": "medium",
      "description": "Feedback screenshots are stored as data URLs inside Firestore documents.",
      "recommendation": "Use Firebase Storage if screenshot volume or size grows."
    },
    {
      "id": "in_memory_rate_limit",
      "severity": "low",
      "description": "Cloud Function rate limiting uses in-memory maps per instance.",
      "recommendation": "Use a shared store or edge protection if abuse increases."
    },
    {
      "id": "duplicated_admin_identity",
      "severity": "medium",
      "description": "Admin emails and identities are configured in several code locations.",
      "recommendation": "Centralize admin authorization with Firebase custom claims or documented config."
    },
    {
      "id": "browser_side_rss_fallbacks",
      "severity": "low",
      "description": "Local news uses browser-side RSS fetches and public CORS proxy fallbacks.",
      "recommendation": "Move critical feed aggregation to a Cloud Function."
    }
  ],
  "expert_review_checklist": [
    "Verify Firebase Hosting rewrites for multi-page deployment.",
    "Test Firestore rules with emulator tests for public create and admin update paths.",
    "Verify CSP against actual production domains and all Cloud Function URLs.",
    "Confirm privacy text matches feedback metadata and usage statistics storage.",
    "Review App Check fallback behavior in browsers where App Check fails.",
    "Review localStorage data lifecycle and user controls.",
    "Define the canonical link registry and audit workflow.",
    "Review accessibility with keyboard, screen reader, mobile and 200 percent zoom.",
    "Review Cloud Function secrets management and use of Firebase Secret Manager.",
    "Review whether Firestore is appropriate for screenshot attachments."
  ]
}
